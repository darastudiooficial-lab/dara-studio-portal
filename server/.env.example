# DARA Studio Email Server Environment Variables
# Copy this file to .env and fill in your credentials

# Gmail SMTP (use App Password, not your regular password)
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Server
PORT=5000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# Admin Portal URL (used in email CTAs)
ADMIN_PORTAL_URL=https://portal.darastudio.com

# Supabase Configuration
# URL: Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# Key: Settings > API > service_role (secret)
# IMPORTANT: Use service_role for server-side persistence to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
